{
  "name": "vanguard-gnl-uikit",
  "version": "2.0.0",
  "description": "A modern dark-themed UI component library with glassmorphism, neuromorphism, and liquid glass aesthetics",
  "main": "./dist/vanguard-gnl-uikit.cjs.js",
  "module": "./dist/vanguard-gnl-uikit.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vanguard-gnl-uikit.es.js",
      "require": "./dist/vanguard-gnl-uikit.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./presets": "./dist/presets.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && mv dist/vanguard-uikit.css dist/vanguard-gnl-uikit.css 2>/dev/null || true",
    "build:all": "node scripts/generate-barrel.js && vite build",
    "build:barrel": "node scripts/generate-barrel.js",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "ui-kit",
    "components",
    "vanguard",
    "dark-theme",
    "glassmorphism",
    "neuromorphism",
    "liquid-glass",
    "tailwind"
  ],
  "author": "Dream-Pixels-Forge",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^4.5.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.294.0",
    "tailwind-merge": "^3.6.0"
  },
  "size-limit": [
    {
      "path": "dist/vanguard-gnl-uikit.es.js",
      "limit": "100 kB"
    }
  ]
}
